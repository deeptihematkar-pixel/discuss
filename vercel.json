{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    },
    {
      "src": "backend/server.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/server.py" },
    { "src": "/(.*)", "dest": "frontend/$1" }
  ],
  "env": {
    "FIREBASE_DB_URL": "@firebase_db_url",
    "JWT_SECRET": "@jwt_secret"
  }
}
